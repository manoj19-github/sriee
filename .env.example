JARVIS_ENV=development
JARVIS_DEBUG=false
HOST=127.0.0.1
PORT=5000
LOG_DIR=logs

DB_HOST=replace-with-database-host
DB_PORT=5432
DB_NAME=replace-with-database-name
DB_USER=replace-with-database-user
DB_PASSWORD=replace-with-secret
DEFAULT_SCHEMA=jarvis

REDIS_HOST=replace-with-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-secret

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
